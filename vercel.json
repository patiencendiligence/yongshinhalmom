{
  "functions": {
    "server.ts": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.ts" },
    { "source": "/policies.html", "destination": "/policies.html" },
    { "source": "/purchase.html", "destination": "/purchase.html" },
    { "source": "/((?!api/|policies\\.html|purchase\\.html).*)", "destination": "/index.html" }
  ]
}
