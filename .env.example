# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# GITHUB_TOKEN: Required for reporting issues to GitHub.
# Create a Personal Access Token (classic) with 'repo' scope.
GITHUB_TOKEN=
GITHUB_REPO_OWNER=patiencendiligence
GITHUB_REPO_NAME=yongshinhalmom

# SYSTEM_INSTRUCTION: Custom prompt for the AI's personality and style.
SYSTEM_INSTRUCTION=

# TIME_LOGIC: Details for Saju calculation (Summertime, Yajashi, etc.)
TIME_LOGIC=
